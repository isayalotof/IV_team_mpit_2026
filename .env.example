# ─────────────────────────────────────────────
# AskData — шаблон переменных окружения
# Скопируйте: cp .env.example .env
# ─────────────────────────────────────────────

# ── LLM провайдер ──────────────────────────────
# Выберите один: claude | gigachat | local
LLM_PROVIDER=claude

# Claude (Anthropic) — рекомендуется
CLAUDE_API_KEY=sk-ant-api03-...
CLAUDE_MODEL=claude-sonnet-4-6

# GigaChat (fallback)
GIGACHAT_CREDENTIALS=
GIGACHAT_MODEL=GigaChat-Pro

# Локальная LLM (OpenAI-compatible, напр. Qwen)
LOCAL_LLM_URL=http://HOST:PORT/v1
LOCAL_LLM_MODEL=qwen-coder-7b
LOCAL_LLM_API_KEY=

# ── Приложение ─────────────────────────────────
# Генерируется: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-random-hex-string

# 1 = создаются демо-пользователи viewer/manager/admin
DEMO_MODE=1

# ── Telegram бот (опционально) ─────────────────
TELEGRAM_BOT_TOKEN=

# ── Email доставка (опционально) ───────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
