FROM node:20-alpine AS build

WORKDIR /app
COPY package*.json ./
RUN npm ci --silent
COPY . .
ENV VITE_API_BASE=/api/v1
RUN npm run build

FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx-prod-inner.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
